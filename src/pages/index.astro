---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articoli = await getCollection('articoli');
const episodi = await getCollection('episodi');

const ultimiArticoli = articoli
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const ultimiEpisodi = episodi
  .sort((a, b) => b.data.number - a.data.number)
  .slice(0, 4);
---
<Base title="Home">
<style>
  .ticker {
    background: var(--orange);
    padding: 0.6rem 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .ticker-inner {
    display: inline-flex;
    animation: ticker 30s linear infinite;
  }
  .ticker-item {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    color: var(--ink);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .ticker-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(0,0,0,0.35);
    flex-shrink: 0;
  }
  @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  .hero {
    min-height: 92vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    border-bottom: 1px solid var(--divider);
  }
  .hero-left {
    padding: 6rem 4rem 4rem 5vw;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }
  .hero-left::before {
    content: 'BASKET';
    position: absolute;
    left: -0.05em;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(10rem, 18vw, 22rem);
    color: rgba(255,255,255,0.025);
    line-height: 1;
    pointer-events: none;
    white-space: nowrap;
    z-index: 0;
  }
  .hero-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hero-eyebrow::before {
    content: '';
    width: 2rem;
    height: 1px;
    background: var(--orange);
    display: block;
  }
  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 8vw, 8rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: var(--cream);
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
  }
  .hero-title em { font-style: normal; color: var(--orange); }
  .hero-desc {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: rgba(244,239,230,0.6);
    max-width: 38ch;
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }
  .btn-primary {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--orange);
    padding: 0.9rem 2rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: #ff6a20; transform: translateY(-1px); }
  .btn-secondary {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .btn-secondary:hover { color: var(--cream); }
  .hero-right {
    background: var(--ink2);
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--divider);
  }
  .hero-right-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 3rem;
    gap: 1px;
    background: var(--divider);
  }
  .hero-stat-bar {
    background: var(--ink2);
    padding: 1.5rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    transition: background 0.2s;
  }
  .hero-stat-bar:hover { background: var(--ink3); }
  .stat-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    color: var(--orange);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.4;
  }
  .featured-tag {
    background: var(--ink2);
    padding: 1.5rem 2rem;
    margin-top: auto;
  }
  .featured-tag-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.5rem;
  }
  .featured-tag-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.1rem;
    color: var(--cream);
    line-height: 1.4;
  }

  section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--divider);
    padding-bottom: 1.25rem;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    color: var(--cream);
  }
  .section-link {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
    text-decoration: none;
  }
  .section-link:hover { text-decoration: underline; }

  .featured-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    grid-template-rows: auto auto;
    gap: 1px;
    background: var(--divider);
    border: 1px solid var(--divider);
  }
  .article-card {
    background: var(--ink);
    text-decoration: none;
    display: block;
    transition: background 0.25s;
    overflow: hidden;
  }
  .article-card:hover { background: var(--ink2); }
  .article-card.tall { grid-row: span 2; }
  .card-thumb {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    filter: grayscale(40%) contrast(1.1);
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  .article-card.tall .card-thumb { height: 320px; }
  .article-card:hover .card-thumb { opacity: 0.9; }
  .card-placeholder {
    width: 100%;
    height: 220px;
    background: var(--ink3);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .article-card.tall .card-placeholder { height: 320px; }
  .card-placeholder-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 5rem;
    color: rgba(255,255,255,0.05);
  }
  .card-body { padding: 1.5rem; }
  .card-category {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.6rem;
  }
  .card-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--cream);
    margin-bottom: 0.6rem;
  }
  .article-card.tall .card-title { font-size: 1.6rem; }
  .card-excerpt {
    font-size: 0.875rem;
    color: rgba(244,239,230,0.5);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-meta {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    font-size: 0.7rem;
    color: var(--muted);
  }

  .podcast-section {
    background: var(--ink2);
    border-top: 1px solid var(--divider);
    border-bottom: 1px solid var(--divider);
  }
  .podcast-section section {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 5rem;
    align-items: start;
  }
  .podcast-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(232,80,10,0.12);
    border: 1px solid rgba(232,80,10,0.25);
    border-radius: 100px;
    padding: 0.4rem 1rem;
    margin-bottom: 1.5rem;
  }
  .podcast-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--orange);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }
  .podcast-badge span {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
  }
  .podcast-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: 0.03em;
    color: var(--cream);
    margin-bottom: 1.5rem;
  }
  .podcast-desc {
    font-size: 0.95rem;
    color: rgba(244,239,230,0.55);
    line-height: 1.75;
    margin-bottom: 2rem;
    max-width: 42ch;
  }
  .platform-links { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .platform-link {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cream);
    border: 1px solid var(--divider);
    padding: 0.6rem 1.2rem;
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .platform-link:hover { border-color: var(--orange); color: var(--orange); }
  .episode-list { display: flex; flex-direction: column; gap: 1px; background: var(--divider); border: 1px solid var(--divider); }
  .episode-item {
    background: var(--ink2);
    padding: 1.5rem;
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.25rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }
  .episode-item:hover { background: var(--ink3); }
  .ep-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    color: rgba(244,239,230,0.12);
    line-height: 1;
  }
  .ep-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1rem;
    color: var(--cream);
    line-height: 1.4;
    margin-bottom: 0.35rem;
  }
  .ep-meta {
    font-size: 0.7rem;
    color: var(--muted);
    display: flex;
    gap: 0.75rem;
  }

  .newsletter-band {
    background: var(--orange);
    padding: 4rem 2rem;
  }
  .newsletter-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .nl-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 4vw, 4rem);
    line-height: 0.95;
    color: var(--ink);
    letter-spacing: 0.03em;
  }
  .nl-subtitle { font-size: 0.95rem; color: rgba(14,13,11,0.6); margin-top: 0.75rem; line-height: 1.6; }
  .nl-form { display: flex; }
  .nl-input {
    flex: 1;
    background: rgba(14,13,11,0.12);
    border: 1.5px solid rgba(14,13,11,0.25);
    border-right: none;
    padding: 0.9rem 1.25rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: var(--ink);
    outline: none;
    border-radius: 2px 0 0 2px;
  }
  .nl-input::placeholder { color: rgba(14,13,11,0.4); }
  .nl-btn {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cream);
    background: var(--ink);
    padding: 0.9rem 1.75rem;
    border: none;
    cursor: pointer;
    border-radius: 0 2px 2px 0;
    white-space: nowrap;
  }
  .nl-btn:hover { background: var(--ink2); }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-right { display: none; }
    .hero-left { padding: 5rem 1.5rem 3rem; }
    .featured-grid { grid-template-columns: 1fr; }
    .article-card.tall { grid-row: auto; }
    .podcast-section section { grid-template-columns: 1fr; gap: 3rem; }
    .newsletter-inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<div class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">Podcast · Basket · Livorno</p>
    <h1 class="hero-title">Dillo<br><em>a</em><br>Boncio</h1>
    <p class="hero-desc">La voce del basket livornese. Analisi, storie, e il meglio dell'EuroLeague — raccontati con passione e senza filtri.</p>
    <div class="hero-actions">
      <a href="/podcast" class="btn-primary">Ascolta il Podcast</a>
      <a href="/articoli" class="btn-secondary">Leggi gli Articoli →</a>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-right-inner">
      <div class="hero-stat-bar">
        <span class="stat-number">{episodi.length || '—'}</span>
        <span class="stat-label">Episodi<br>pubblicati</span>
      </div>
      <div class="hero-stat-bar">
        <span class="stat-number">{articoli.length || '—'}</span>
        <span class="stat-label">Articoli<br>pubblicati</span>
      </div>
      <div class="hero-stat-bar">
        <span class="stat-number">100%</span>
        <span class="stat-label">Livornese<br>DOC</span>
      </div>
      {ultimiEpisodi[0] && (
        <div class="featured-tag">
          <p class="featured-tag-label">Ultimo Episodio</p>
          <p class="featured-tag-title">{ultimiEpisodi[0].data.title}</p>
        </div>
      )}
    </div>
  </div>
</div>

<div class="ticker" aria-hidden="true">
  <div class="ticker-inner">
    {['Basket Livornese','EuroLeague Analysis','Nuovo Formato 2025','Dillo a Boncio Podcast','Pallacanestro Livorno','Play-In Tournament','Analisi Tattica','Storie del Basket','Basket Livornese','EuroLeague Analysis','Nuovo Formato 2025','Dillo a Boncio Podcast','Pallacanestro Livorno','Play-In Tournament','Analisi Tattica','Storie del Basket'].map(item => (
      <span class="ticker-item">{item} <span class="ticker-dot"></span></span>
    ))}
  </div>
</div>

<section id="articoli">
  <div class="section-header">
    <h2 class="section-title">In Evidenza</h2>
    <a href="/articoli" class="section-link">Tutti gli Articoli →</a>
  </div>
  {ultimiArticoli.length === 0 ? (
    <div style="text-align:center;padding:4rem;color:var(--muted);">
      <p style="font-family:'Bebas Neue',sans-serif;font-size:2rem;margin-bottom:1rem;">Nessun articolo ancora</p>
      <p>Gli articoli pubblicati dal CMS appariranno qui automaticamente.</p>
    </div>
  ) : (
    <div class="featured-grid">
      {ultimiArticoli.map((articolo, i) => (
        <a href={`/articoli/${articolo.slug}`} class={`article-card${i === 0 ? ' tall' : ''}`}>
          {articolo.data.thumbnail
            ? <img src={articolo.data.thumbnail} alt={articolo.data.title} class="card-thumb" />
            : <div class="card-placeholder"><span class="card-placeholder-text">{articolo.data.category.slice(0,2).toUpperCase()}</span></div>
          }
          <div class="card-body">
            <p class="card-category">{articolo.data.category}</p>
            <h3 class="card-title">{articolo.data.title}</h3>
            <p class="card-excerpt">{articolo.data.excerpt}</p>
            <div class="card-meta">
              <span>{new Date(articolo.data.date).toLocaleDateString('it-IT', {day:'numeric',month:'long',year:'numeric'})}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}
</section>

<div class="podcast-section" id="podcast">
  <section>
    <div>
      <div class="podcast-badge">
        <span class="podcast-badge-dot"></span>
        <span>Ora disponibile</span>
      </div>
      <h2 class="podcast-headline">IL PODCAST<br>SUL BASKET<br>LIVORNESE</h2>
      <p class="podcast-desc">Ogni episodio un'immersione nel basket locale e internazionale. Ospiti, analisi tattiche, storie dimenticate e tanto EuroLeague.</p>
      <div class="platform-links">
        
        
        <a href="https://www.youtube.com/@DilloaBoncio" class="platform-link">YouTube</a>
      </div>
    </div>
    <div>
      {ultimiEpisodi.length === 0 ? (
        <div style="color:var(--muted);padding:2rem;border:1px solid var(--divider);">
          <p>Gli episodi appariranno qui automaticamente.</p>
        </div>
      ) : (
        <div class="episode-list">
          {ultimiEpisodi.map(ep => (
            <a href={`/podcast/${ep.slug}`} class="episode-item">
              <span class="ep-number">{ep.data.number}</span>
              <div>
                <p class="ep-title">{ep.data.title}</p>
                <div class="ep-meta">
                  <span>{ep.data.duration}</span>
                  <span>{new Date(ep.data.date).toLocaleDateString('it-IT', {day:'numeric',month:'short',year:'numeric'})}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</div>

<div class="newsletter-band" id="newsletter">
  <div class="newsletter-inner">
    <div>
      <h2 class="nl-title">Non Perdere<br>Nessun Episodio</h2>
      <p class="nl-subtitle">Ricevi ogni settimana i nuovi episodi, gli articoli freschi e le analisi EuroLeague direttamente nella tua inbox.</p>
    </div>
    <div>
      <form class="nl-form" name="newsletter" method="POST" data-netlify="true">
        <input class="nl-input" type="email" name="email" placeholder="La tua email..." required>
        <button class="nl-btn" type="submit">Iscriviti</button>
      </form>
    </div>
  </div>
</div>
</Base>
